{
  "name": "@baran/sdk",
  "version": "0.1.0",
  "description": "TypeScript/Node.js SDK for Baran OS agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "eventsource": "^2.0.2"
  },
  "devDependencies": {
    "@types/eventsource": "^1.1.15",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "testTimeout": 30000,
    "moduleNameMapper": {
      "^(\\.\\.?/.+)\\.js$": "$1"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["baran", "agent", "event-driven"],
  "license": "MIT"
}
